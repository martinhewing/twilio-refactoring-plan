server {
    listen 80;
    server_name twilio-refactoring-plan.connectaiml.com;

    location / {
        proxy_pass         http://127.0.0.1:8394;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}

# After certbot runs, it will add the 443 block automatically:
#   sudo certbot --nginx -d twilio-refactoring-plan.connectaiml.com
